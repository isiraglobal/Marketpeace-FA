.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# Logs & Debugging
*.log
npm_output.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor & IDE Specific
.vscode/
.idea/
*.swp
*.swo
*~
*.code-workspace
.code-workspace

# Temporary & Scratch Files
scratch/
temp_legal/
tmp/

# Python Cache
__pycache__/
*.pyc
*.pyo

# Vercel Configuration & Cache
.vercel/

