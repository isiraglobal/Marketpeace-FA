# ============================================================
# MARKETPEACE — Environment Variables Template
# ============================================================
# Copy this file to `.env.local` and fill in your values.
# NEVER commit .env.local or any .env* file to git.
# All these values MUST be set in your Vercel dashboard for production.
# ============================================================

# --- Stripe ---
# Your Stripe secret key (starts with sk_live_ for production, sk_test_ for testing)
# NEVER use sk_live_ in development or expose this anywhere client-side
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Stripe webhook signing secret (from Stripe Dashboard → Webhooks → Signing Secret)
# Required for CRIT-1: webhook signature verification
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- Google Apps Script ---
# The deployment URL of your Google Apps Script web app
# Keep this server-side ONLY — never expose to the browser
# Format: https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# --- Internal Security ---
# A strong random secret shared between your API handlers and the Apps Script
# This prevents unauthorized calls to the Apps Script updateStatus endpoint
# Generate with: openssl rand -base64 32
INTERNAL_WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# --- Notion (Optional) ---
# Only needed if using Notion integration
NOTION_API_KEY=secret_REPLACE_ME
NOTION_DATABASE_ID=REPLACE_ME

# --- App URL ---
# Your production domain — used for Stripe redirect URLs (HIGH-6 fix)
# Do NOT include a trailing slash
# Development: http://localhost:5173
# Production: https://marketpeace.com
APP_URL=http://localhost:5173

# --- Note on Discord Webhook ---
# DISCORD_WEBHOOK_URL is configured as a Script Property in Google Apps Script,
# not here. If you've been using the old webhook URL, regenerate it immediately
# in Discord → Server Settings → Integrations → Webhooks.
